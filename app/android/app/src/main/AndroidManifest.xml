<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Network access (Supabase auth/sync). Required in the main manifest so it
         ships in RELEASE builds; Flutter only auto-adds it to the debug manifest. -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Local notifications (daily reminder) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <!-- Minute-accurate PRAYER/adhan notifications (core feature). Granted by
         default on Android 12-13; DENIED BY DEFAULT for new installs on
         Android 14+, where the user grants «Alarms and reminders» via the
         prayer-settings tile (requestExactAlarmsPermission). Scheduling
         degrades to inexact whenever the grant is absent. Everything except
         the prayer family stays inexact by design. Play policy: justified as
         user-visible, time-critical religious reminders. NEVER swap this for
         USE_EXACT_ALARM (Play restricts that to alarm-clock/calendar apps). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <!-- App-usage monitoring for the phone-addiction habit: a SPECIAL permission
         the user grants manually in system settings (Usage access); it cannot be
         requested at runtime. tools:ignore silences the lint for declaring it. -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions"/>
    <!-- Prayer-times engine: one coarse fix to pick the nearest city; the
         astronomical calculation itself is fully offline. -->
    <!-- COARSE ONLY, deliberately: matching the nearest of 306 bundled cities
         needs km-level accuracy, and the geolocator call already asks for
         LocationAccuracy.low. Requesting FINE would be an unjustifiable
         precise-location declaration at store review. Do not add it back. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <application
        android:label="عوّاد"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Lets home_widget mark launches that came from the widget. -->
            <intent-filter>
                <action android:name="es.antonborri.home_widget.action.LAUNCH"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- flutter_local_notifications: v18 does NOT merge these receivers from
             its own library manifest, they MUST be declared here (per the plugin
             README). Without the first one, every scheduled reminder's alarm
             broadcasts to a non-existent component and is silently dropped: no
             reminder can EVER fire. The second reschedules everything after a
             reboot or an app update (it is what consumes RECEIVE_BOOT_COMPLETED
             above); without it reminders die on every restart. -->
        <receiver android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver" />
        <receiver android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- Home-screen widget (streak + quick log). AwwadWidgetProvider
             renders the card; HomeWidgetBackgroundReceiver runs the Dart
             quick-log callback in the background when the button is tapped
             (home_widget package requires declaring it here). -->
        <receiver android:name=".AwwadWidgetProvider"
            android:exported="true"
            android:label="عوّاد">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data android:name="android.appwidget.provider"
                android:resource="@xml/awwad_widget_info"/>
        </receiver>
        <!-- exported=false ON PURPOSE (differs from the plugin example): the
             widget button's PendingIntent is same-UID so it still reaches a
             non-exported receiver, while a co-installed app can no longer
             forge awwad://quicklog broadcasts to fake habit entries. -->
        <receiver android:name="es.antonborri.home_widget.HomeWidgetBackgroundReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="es.antonborri.home_widget.action.BACKGROUND"/>
            </intent-filter>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Package visibility (Android 11+): needed so the usage screen can
             resolve display names/icons of the user's launchable apps. -->
        <intent>
            <action android:name="android.intent.action.MAIN"/>
            <category android:name="android.intent.category.LAUNCHER"/>
        </intent>
    </queries>
</manifest>
