---
import Base from '../layouts/Base.astro';
import { t, LOCALES, PAGES, WEB_APP_URL } from '../content/site.js';
import { POSTS, postsForLocale } from '../content/posts.js';

const BLOG = {
  ar: { title: 'المدوّنة: مقالات عن العادات', desc: 'مقالات عن كسر العادات السيّئة وبناء عادات جديدة بمنهجٍ علميّ.', read: 'اقرأ المزيد', faq: 'أسئلة شائعة', published: 'نُشر في' },
  en: { title: 'Blog: articles on habits', desc: 'Articles on breaking bad habits and building new ones with a science-based method.', read: 'Read more', faq: 'FAQ', published: 'Published' },
  fr: { title: 'Blog : articles sur les habitudes', desc: 'Articles pour arrêter de mauvaises habitudes et en bâtir de nouvelles.', read: 'Lire la suite', faq: 'FAQ', published: 'Publié le' },
};

export function getStaticPaths() {
  const out = [];
  for (const lang of LOCALES) {
    const pfx = lang === 'ar' ? '' : `${lang}/`;
    // static pages
    for (const pageKey of Object.keys(PAGES)) {
      const slug = PAGES[pageKey];
      const path = lang === 'ar'
        ? (slug === '' ? undefined : slug)
        : (slug === '' ? lang : `${lang}/${slug}`);
      out.push({ params: { path }, props: { lang, pageKey, pageSlug: slug } });
    }
    // blog index
    out.push({ params: { path: `${pfx}blog` }, props: { lang, pageKey: 'blog', pageSlug: 'blog' } });
    // posts
    for (const post of POSTS) {
      out.push({
        params: { path: `${pfx}blog/${post.slug}` },
        props: { lang, pageKey: 'post', postSlug: post.slug, pageSlug: `blog/${post.slug}` },
      });
    }
  }
  return out;
}

const { lang, pageKey, postSlug, pageSlug } = Astro.props;
const tt = t[lang];
const isHome = pageKey === 'home';
const isMarketing = pageKey === 'break-habit' || pageKey === 'build-habit';
const isBlog = pageKey === 'blog';
const isPost = pageKey === 'post';
const page = (!isBlog && !isPost) ? tt.pages[pageKey] : null;
const post = isPost ? POSTS.find((p) => p.slug === postSlug) : null;
const blogPfx = lang === 'ar' ? '' : `/${lang}`;

const site = Astro.site?.toString().replace(/\/$/, '') ?? '';

function appHref() { return 'https://app.awwad.app'; }

// SEO title/description per page type
let title, description;
if (isBlog) { title = BLOG[lang].title; description = BLOG[lang].desc; }
else if (isPost) { title = `${post.title[lang]} | عوّاد`; description = post.description[lang]; }
else { title = page.title; description = page.description; }

// Article + FAQ JSON-LD for posts
const articleLd = isPost ? {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: post.title[lang], description: post.description[lang],
  datePublished: post.date, inLanguage: lang,
  author: { '@type': 'Organization', name: 'Awwad' },
  publisher: { '@type': 'Organization', name: 'Awwad' },
  mainEntityOfPage: site + (lang === 'ar' ? '' : `/${lang}`) + `/blog/${post.slug}`,
} : null;
const faqLd = isPost && post.faq[lang]?.length ? {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: post.faq[lang].map((f) => ({
    '@type': 'Question', name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;
---
<Base lang={lang} pageKey={pageKey} pageSlug={pageSlug} title={title} description={description}>
  {isHome && (
    <>
      <section class="hero">
        <p class="slogan">{tt.slogan}</p>
        <h1 class="sub">{page.sub}</h1>
        <div class="cta-row">
        <button class="btn btn-lg" type="button" onclick="awDownload()">{tt.cta_download}</button>
        <span class="cta-or">{tt.cta_or}</span>
        <a class="btn btn-ghost btn-sm" href={WEB_APP_URL}>{tt.cta_webversion}</a>
      </div>
      </section>
      <h2 class="section-title">{page.sectionTitle}</h2>
      <div class="cards">
        {page.tracks.map((tr) => (
          <a class="card" href={`${blogPfx}/${tr.href}`}>
            <div class="icon">{tr.icon}</div>
            <h3>{tr.title}</h3>
            <p>{tr.desc}</p>
          </a>
        ))}
      </div>
      <h2 class="section-title">{page.featuresTitle}</h2>
      <div class="features">
        {page.features.map((f) => (
          <div class="feature">
            <span class="icon">{f.icon}</span>
            <div><h3>{f.h}</h3><p>{f.p}</p></div>
          </div>
        ))}
      </div>
    </>
  )}

  {isMarketing && (
    <article class="prose">
      <h1>{page.h1}</h1>
      <p class="sub" style="color:var(--muted);font-size:17px;margin-top:10px">{page.intro}</p>
      {page.blocks.map((b) => (<><h2>{b.h}</h2><p>{b.p}</p></>))}
      {page.resource && (
        <aside style="margin-top:28px;padding:20px;border:1px solid color-mix(in srgb, var(--accent2) 45%, transparent);border-radius:14px;background:color-mix(in srgb, var(--accent2) 8%, transparent)">
          <h2 style="margin-top:0">{page.resource.h}</h2>
          <p>{page.resource.p}</p>
          <a class="btn" href={page.resource.url} target="_blank" rel="noopener noreferrer">{page.resource.cta} →</a>
        </aside>
      )}
      <div class="cta-row">
        <button class="btn btn-lg" type="button" onclick="awDownload()">{tt.cta_download}</button>
        <span class="cta-or">{tt.cta_or}</span>
        <a class="btn btn-ghost btn-sm" href={WEB_APP_URL}>{tt.cta_webversion}</a>
      </div>
    </article>
  )}

  {(!isHome && !isMarketing && !isBlog && !isPost) && (
    <article class="prose">
      <h1>{page.h1}</h1>
      {page.blocks.map((b) => (<><h2>{b.h}</h2><p>{b.p}</p></>))}
    </article>
  )}

  {isBlog && (
    <section>
      <h1>{BLOG[lang].title}</h1>
      <p class="sub" style="color:var(--muted);margin-top:8px">{BLOG[lang].desc}</p>
      <div class="cards" style="margin-top:24px">
        {postsForLocale().map((p) => (
          <a class="card" href={`${blogPfx}/blog/${p.slug}`}>
            <h3>{p.title[lang]}</h3>
            <p>{p.description[lang]}</p>
            <p style="color:var(--accent2);font-size:12px;margin-top:8px">{BLOG[lang].read} →</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {isPost && (
    <article class="prose">
      <p style="color:var(--muted);font-size:13px">{BLOG[lang].published} {post.date}</p>
      <h1>{post.title[lang]}</h1>
      <p class="sub" style="color:var(--muted);font-size:17px;margin-top:10px">{post.intro[lang]}</p>
      {post.sections[lang].map((b) => (<><h2>{b.h}</h2><p>{b.p}</p></>))}
      {post.faq[lang]?.length > 0 && (
        <>
          <h2>{BLOG[lang].faq}</h2>
          {post.faq[lang].map((f) => (<><h3>{f.q}</h3><p>{f.a}</p></>))}
        </>
      )}
      <div class="cta-row">
        <button class="btn btn-lg" type="button" onclick="awDownload()">{tt.cta_download}</button>
        <span class="cta-or">{tt.cta_or}</span>
        <a class="btn btn-ghost btn-sm" href={WEB_APP_URL}>{tt.cta_webversion}</a>
      </div>
      <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
      {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
    </article>
  )}
</Base>
