---
import { t, DIR, LANG_NAME, LOCALES, OG_LOCALE, PAGES, CREDIT_URL, WEB_APP_URL, STORE, GTM_ID } from '../content/site.js';

const { lang, pageKey, title, description, pageSlug } = Astro.props;
const dir = DIR[lang];
const tt = t[lang];

function localizedPath(l, key) {
  const slug = PAGES[key] ?? '';
  const base = l === 'ar' ? '' : `/${l}`;
  return `${base}/${slug}` || '/';
}
// locale-independent slug (used for blog/post pages not in PAGES)
function localizedSlug(l, slug) {
  const base = l === 'ar' ? '' : `/${l}`;
  return `${base}/${slug}` || '/';
}

const curSlug = pageSlug ?? PAGES[pageKey] ?? '';
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = site + localizedSlug(lang, curSlug);
const alternates = LOCALES.map((l) => ({ l, href: site + localizedSlug(l, curSlug) }));
const ogImage = site + '/og-image.png';

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Awwad',
  url: site + '/',
  sameAs: [CREDIT_URL],
};
const appLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Awwad',
  operatingSystem: 'Android, iOS, Web',
  applicationCategory: 'HealthApplication',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0e14" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.l} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={site + localizedSlug('ar', curSlug)} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Awwad" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Awwad" />
    <meta property="og:locale" content={OG_LOCALE[lang]} />
    {LOCALES.filter((l) => l !== lang).map((l) => (
      <meta property="og:locale:alternate" content={OG_LOCALE[l]} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="/fonts/SalmaArabic-Black.otf" as="font" type="font/otf" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {pageKey === 'home' && (
      <script type="application/ld+json" set:html={JSON.stringify(appLd)} />
    )}

    <!-- privacy-light data layer (GTM-style; third-party loads ONLY when
         GTM_ID is set in site.js - empty id keeps the site cookie-free) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'page_view', path: location.pathname, locale: document.documentElement.lang });
    </script>
    {GTM_ID && (
      <script is:inline define:vars={{ gtmId: GTM_ID }}>
        (function (w, d, s, l, i) {
          w[l] = w[l] || [];
          w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var f = d.getElementsByTagName(s)[0], j = d.createElement(s);
          j.async = true;
          j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i;
          f.parentNode.insertBefore(j, f);
        })(window, document, 'script', 'dataLayer', gtmId);
      </script>
    )}
  </head>
  <body>
    {GTM_ID && (
      <noscript><iframe src={'https://www.googletagmanager.com/ns.html?id=' + GTM_ID} height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    )}
    <header class="site-header">
      <a class="brand" href={localizedPath(lang, 'home')}>
        <span class="brand-mark"><img src="/logo-mark.png" alt="" width="24" height="24" /></span>
        <span>{tt.brand}</span>
      </a>
      <nav class="nav">
        <a class="nav-login" href={WEB_APP_URL}>{tt.nav.login}</a>
        <a href={localizedPath(lang, 'break-habit')}>{tt.nav.break}</a>
        <a href={localizedPath(lang, 'build-habit')}>{tt.nav.build}</a>
        <a href={localizedSlug(lang, 'blog')}>{({ ar: 'المدوّنة', en: 'Blog', fr: 'Blog' })[lang]}</a>
      </nav>
      <div class="lang-switch">
        {LOCALES.map((l) => (
          <a
            href={localizedPath(l, pageKey)}
            class={l === lang ? 'active' : ''}
            hreflang={l}
            aria-label={LANG_NAME[l]}>{l.toUpperCase()}</a>
        ))}
      </div>
      <a class="nav-account" href={WEB_APP_URL}>{tt.nav.account}</a>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <p class="disclaimer">{tt.footer_disclaimer}</p>
      <nav class="footer-nav">
        <a href={localizedPath(lang, 'privacy')}>{tt.nav.privacy}</a>
        <a href={localizedPath(lang, 'terms')}>{tt.nav.terms}</a>
      </nav>
      <p class="volunteer">{tt.footer_volunteer}</p>
      <p class="copyright">
        © {tt.footer_rights} ·
        <a href={CREDIT_URL} target="_blank" rel="noopener">Morad Arafa</a>
      </p>
    </footer>

    <div id="aw-dl" class="aw-dl" aria-hidden="true">
      <div class="aw-dl-box">
        <button class="aw-dl-close" id="aw-dl-x" aria-label="close">✕</button>
        <p class="aw-dl-title">{tt.dl_choose}</p>
        {!(STORE.androidLive && STORE.iosLive) && (
          <p class="aw-dl-soon">{tt.dl_soon}</p>
        )}
        <a class="btn" id="aw-dl-android" target="_blank" rel="noopener">{tt.dl_android}</a>
        <a class="btn btn-ghost" id="aw-dl-ios" target="_blank" rel="noopener">{tt.dl_ios}</a>
      </div>
    </div>

    <script is:inline define:vars={{ store: STORE, webApp: WEB_APP_URL }}>
      (function () {
        // Custom events for the data layer (consumed by GTM once GTM_ID is set;
        // harmless no-op pushes otherwise).
        function pushCta(cta) {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'cta_click', cta: cta, locale: document.documentElement.lang });
        }
        // Until an app is PUBLISHED (store.androidLive / store.iosLive), its
        // download target is the live web app, never a dead store page.
        var androidHref = store.androidLive ? store.android : webApp;
        var iosHref = store.iosLive ? store.ios : webApp;
        var modal = document.getElementById('aw-dl');
        var a = document.getElementById('aw-dl-android');
        var i = document.getElementById('aw-dl-ios');
        if (a) a.href = androidHref;
        if (i) i.href = iosHref;
        if (a) a.addEventListener('click', function () { pushCta(store.androidLive ? 'store' : 'webapp'); });
        if (i) i.addEventListener('click', function () { pushCta(store.iosLive ? 'store' : 'webapp'); });
        var x = document.getElementById('aw-dl-x');
        if (x) x.addEventListener('click', function () { modal.style.display = 'none'; });
        if (modal) modal.addEventListener('click', function (e) { if (e.target === modal) modal.style.display = 'none'; });
        window.awDownload = function () {
          pushCta('download');
          var ua = (navigator.userAgent || '').toLowerCase();
          if (ua.indexOf('android') > -1) { window.location.href = androidHref; return; }
          if (/iphone|ipad|ipod/.test(ua)) { window.location.href = iosHref; return; }
          if (modal) modal.style.display = 'flex';
        };
        // The "use the web version" CTA buttons (not the nav links).
        var webCtas = document.querySelectorAll('.cta-row a.btn-ghost');
        for (var k = 0; k < webCtas.length; k++) {
          webCtas[k].addEventListener('click', function () { pushCta('webapp'); });
        }
      })();
    </script>


    <style is:global>
      /* Salma Arabic — display font for headings (self-hosted). */
      @font-face {
        font-family: 'Salma Arabic';
        src: url('/fonts/SalmaArabic-Bold.otf') format('opentype');
        font-weight: 700; font-style: normal; font-display: swap;
      }
      @font-face {
        font-family: 'Salma Arabic';
        src: url('/fonts/SalmaArabic-Black.otf') format('opentype');
        font-weight: 800 900; font-style: normal; font-display: swap;
      }
      :root {
        --bg: #0a0e14; --surface: #121a24; --surface-2: #16202c;
        --border: rgba(255,255,255,.08); --border-strong: rgba(255,255,255,.14);
        --accent: #2dd4bf; --accent-strong: #14b8a6; --accent-ink: #04231e;
        --text: #d6e0ec; --muted: #8294a6; --heading: #f3f8ff;
        --radius: 18px; --maxw: 1100px;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Cairo', system-ui, -apple-system, sans-serif;
        color: var(--text);
        line-height: 1.75; min-height: 100dvh;
        display: flex; flex-direction: column;
        -webkit-font-smoothing: antialiased; position: relative; overflow-x: hidden;
        background-color: var(--bg);
        background-image:
          radial-gradient(60% 50% at 82% -5%, rgba(45,212,191,.11), transparent 60%),
          radial-gradient(48% 42% at 8% 0%, rgba(79,142,247,.08), transparent 55%),
          radial-gradient(70% 60% at 50% 112%, rgba(45,212,191,.06), transparent 60%);
        background-attachment: fixed; background-repeat: no-repeat;
      }
      a { color: var(--accent); text-decoration: none; transition: color .2s; }
      a:hover { color: var(--accent-strong); }
      .container { max-width: 820px; margin: 0 auto; padding: 40px 22px 72px; flex: 1; width: 100%; }

      h1, h2, h3, .brand, .section-title {
        font-family: 'Salma Arabic', 'Cairo', system-ui, sans-serif;
        color: var(--heading); letter-spacing: 0; line-height: 1.5;
      }
      h1 { font-size: clamp(32px, 5.6vw, 50px); line-height: 1.45; font-weight: 700; }
      h2 { font-size: clamp(20px, 3vw, 26px); margin-top: 6px; font-weight: 700; }
      h3 { font-size: 17px; font-weight: 700; }
      p { color: var(--text); }

      .site-header {
        position: sticky; top: 0; z-index: 20;
        display: flex; align-items: center; gap: 16px;
        padding: 13px 22px; width: 100%; max-width: var(--maxw); margin: 0 auto; flex-wrap: wrap;
        background: rgba(10,14,20,.92);
        border-bottom: 1px solid var(--border);
      }
      .brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 22px; }
      .brand:hover { color: var(--heading); }
      .brand-mark {
        display: grid; place-items: center; width: 34px; height: 34px; border-radius: 11px;
        background: linear-gradient(145deg, rgba(45,212,191,.24), rgba(79,142,247,.12));
        border: 1px solid var(--border-strong); font-size: 18px;
      }
      .nav { display: flex; gap: 4px; margin-inline-start: auto; }
      .nav a {
        color: var(--muted); font-size: 14px; font-weight: 600; padding: 7px 12px; border-radius: 9px;
        transition: color .2s, background .2s;
      }
      .nav a:hover { color: var(--heading); background: var(--surface); }
      .nav-login { color: var(--accent); font-weight: 700; }
      .nav-account {
        color: var(--accent); font-size: 14px; font-weight: 700;
        padding: 7px 14px; border-radius: 999px; border: 1px solid var(--border-strong);
        background: var(--surface); white-space: nowrap;
      }
      .nav-account:hover { background: rgba(45,212,191,.08); color: var(--accent-strong); }
      .lang-switch { display: flex; gap: 3px; padding: 3px; border: 1px solid var(--border); border-radius: 999px; background: var(--surface); }
      .lang-switch a { font-size: 12px; font-weight: 700; color: var(--muted); padding: 4px 11px; border-radius: 999px; }
      .lang-switch a.active { color: var(--accent-ink); background: var(--accent); }

      .hero { text-align: center; padding: 20px 0 12px; }
      .slogan {
        display: inline-block; color: var(--accent); font-weight: 700; font-size: 14px; margin-top: 16px;
        padding: 5px 15px; border: 1px solid var(--border-strong); border-radius: 999px;
        background: rgba(45,212,191,.10);
      }
      .hero .sub, .sub { color: var(--muted); font-size: clamp(16px, 2.2vw, 19px); margin-top: 16px; max-width: 54ch; margin-inline: auto; }
      .btn {
        display: inline-flex; align-items: center; gap: 8px;
        background: var(--accent); color: var(--accent-ink);
        padding: 13px 30px; border-radius: 14px; font-weight: 700; margin-top: 26px;
        box-shadow: 0 8px 30px -10px rgba(45,212,191,.5);
        transition: transform .2s, box-shadow .2s, background .2s;
      }
      .btn:hover { color: var(--accent-ink); background: var(--accent-strong); transform: translateY(-2px); box-shadow: 0 14px 38px -12px rgba(45,212,191,.6); }
      .btn:active { transform: translateY(0) scale(.98); }
      .cta-row { display: flex; flex-direction: column; gap: 10px; justify-content: center; align-items: center; margin-top: 26px; }
      .cta-row .btn { margin-top: 0; }
      .btn-lg { padding: 17px 46px; font-size: 18px; border-radius: 16px; }
      .btn-sm { padding: 10px 26px; font-size: 14px; }
      .cta-or { color: var(--muted); font-size: 13px; font-weight: 700; letter-spacing: .5px; }
      .btn-ghost { background: transparent; color: var(--accent); border: 1px solid var(--border-strong); box-shadow: none; }
      .btn-ghost:hover { background: rgba(45,212,191,.08); color: var(--accent-strong); }
      .aw-dl { display: none; position: fixed; inset: 0; z-index: 50; background: rgba(0,0,0,.6); align-items: center; justify-content: center; padding: 20px; }
      .aw-dl-box { position: relative; background: var(--surface-2); border: 1px solid var(--border-strong); border-radius: 16px; padding: 30px 22px 24px; width: 100%; max-width: 340px; text-align: center; display: flex; flex-direction: column; gap: 12px; }
      .aw-dl-title { font-weight: 700; color: var(--heading); margin-bottom: 4px; }
      .aw-dl-soon { color: var(--muted); font-size: 12.5px; margin: -4px 0 6px; line-height: 1.7; }
      .aw-dl-box .btn { margin-top: 0; justify-content: center; }
      .aw-dl-close { position: absolute; top: 8px; inset-inline-end: 12px; background: none; border: none; color: var(--muted); font-size: 18px; cursor: pointer; }

      .section-title { text-align: center; margin: 56px 0 6px; font-size: clamp(23px, 3.8vw, 33px); font-weight: 700; }
      .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin: 26px 0; }
      .card {
        position: relative; display: block;
        background: linear-gradient(180deg, var(--surface-2), var(--surface));
        border: 1px solid var(--border); border-radius: var(--radius); padding: 24px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
        transition: transform .25s cubic-bezier(.16,1,.3,1), border-color .25s, box-shadow .25s;
      }
      a.card:hover { transform: translateY(-4px); border-color: var(--border-strong); color: var(--text); box-shadow: 0 18px 44px -22px rgba(0,0,0,.85); }
      a.card:hover h3 { color: var(--accent); }
      .card .icon { font-size: 32px; }
      .card h3 { margin: 12px 0 6px; transition: color .2s; }
      .card p { color: var(--muted); font-size: 14.5px; }
      .features { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px; }
      .feature {
        display: flex; gap: 14px; align-items: flex-start;
        background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 18px;
      }
      .feature .icon {
        font-size: 20px; flex: none; display: grid; place-items: center; width: 40px; height: 40px;
        border-radius: 11px; background: rgba(45,212,191,.10); border: 1px solid var(--border);
      }
      .feature h3 { font-size: 15.5px; }
      .feature p { color: var(--muted); font-size: 13.5px; margin-top: 2px; }

      .prose { max-width: 70ch; }
      .prose h1 { margin-bottom: 6px; }
      .prose h2 { margin-top: 30px; }
      .prose p { color: var(--text); margin-top: 8px; }
      .prose h3 { margin-top: 16px; color: var(--accent); }

      .site-footer {
        border-top: 1px solid var(--border); padding: 36px 22px 40px;
        text-align: center; max-width: var(--maxw); margin: 56px auto 0; width: 100%;
      }
      .site-footer .disclaimer { color: var(--muted); font-size: 12.5px; max-width: 620px; margin: 0 auto 16px; line-height: 1.7; }
      .footer-nav { display: flex; gap: 18px; justify-content: center; flex-wrap: wrap; margin-bottom: 14px; }
      .footer-nav a { color: var(--muted); font-size: 13px; font-weight: 600; }
      .footer-nav a:hover { color: var(--accent); }
      .volunteer { color: var(--accent); font-size: 12.5px; margin-bottom: 8px; opacity: .92; }
      .copyright { color: var(--muted); font-size: 13px; }

      /* CSS-only reveal: a subtle slide that auto-plays on load. It animates
         transform ONLY (never opacity), so content is always visible even if the
         animation never runs (fail-open). No JS / IntersectionObserver dependency. */
      @keyframes fadeUp { from { transform: translateY(14px); } to { transform: none; } }
      .hero > *, .section-title, .card, .feature, .prose > h2, .prose > p {
        animation: fadeUp .6s cubic-bezier(.16,1,.3,1) both;
      }
      .cards .card:nth-child(2) { animation-delay: .09s; }
      .features .feature:nth-child(2) { animation-delay: .06s; }
      .features .feature:nth-child(3) { animation-delay: .12s; }
      .features .feature:nth-child(4) { animation-delay: .18s; }

      @media (max-width: 640px) {
        .cards, .features { grid-template-columns: 1fr; }
        .nav { margin-inline-start: 0; order: 3; width: 100%; justify-content: center; }
        .hero { padding: 16px 0 8px; }
      }
      @media (prefers-reduced-motion: reduce) {
        .hero > *, .section-title, .card, .feature, .prose > h2, .prose > p { animation: none; }
        html { scroll-behavior: auto; }
        .btn:hover, a.card:hover { transform: none; }
      }
    </style>
  </body>
</html>
